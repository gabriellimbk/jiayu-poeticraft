# Supabase public client config. These are safe to expose in the browser.
VITE_SUPABASE_URL="https://YOUR_PROJECT_ID.supabase.co"
VITE_SUPABASE_ANON_KEY="YOUR_SUPABASE_ANON_KEY"

# Server-only. Configure in Vercel Project Settings -> Environment Variables.
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# Optional deployment URL used by hosting tooling or future callbacks.
APP_URL="https://your-app.vercel.app"
